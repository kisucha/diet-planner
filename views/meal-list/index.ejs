<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>식단 구성 리스트 관리</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        /* 페이지네이션 스타일 */
        .pagination {
            display: flex;
            justify-content: center;
            margin: 20px 0;
        }

        .pagination button {
            padding: 8px 16px;
            margin: 0 4px;
            background-color: #f0f0f0;
            border: 1px solid #ddd;
            cursor: pointer;
        }

        .pagination button.active {
            background-color: #4CAF50;
            color: white;
        }

        .pagination button:disabled {
            background-color: #ddd;
            cursor: not-allowed;
        }

        /* 탭 스타일 */
        .tabs {
            display: flex;
            margin-bottom: 20px;
        }

        .tab {
            padding: 10px 20px;
            background-color: #f0f0f0;
            cursor: pointer;
            border: 1px solid #ddd;
            border-bottom: none;
        }

        .tab.active {
            background-color: white;
            border-bottom: 1px solid white;
            margin-bottom: -1px;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }

        /* 테이블 스타일 */
        .meal-list-table {
            width: 100%;
            border-collapse: collapse;
        }

        .meal-list-table th,
        .meal-list-table td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: left;
        }

        .meal-list-table th {
            background-color: #f2f2f2;
        }

        /* 체크박스 스타일 */
        .checkbox-cell {
            text-align: center;
        }

        /* 모달 스타일 */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.4);
        }

        .modal-content {
            background-color: white;
            margin: 15% auto;
            padding: 20px;
            border: 1px solid #888;
            width: 80%;
            max-width: 600px;
        }

        .close {
            color: #aaa;
            float: right;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
        }

        .close:hover {
            color: black;
        }

        /* 필터 스타일 */
        .filters {
            margin-bottom: 20px;
        }

        .filter-select {
            margin-right: 10px;
            padding: 5px;
        }
    </style>
</head>
<body>
    <header>
        <h1>식단 구성 리스트 관리</h1>
    </header>

    <main>
        <!-- 탭 네비게이션 -->
        <div class="tabs">
            <div class="tab active" data-tab="main-dish">메인요리</div>
            <div class="tab" data-tab="side-dish">반찬</div>
            <div class="tab" data-tab="special">야식/별식</div>
        </div>

        <!-- 메인요리 탭 -->
        <div id="main-dish" class="tab-content active">
            <h2>메인요리 관리</h2>

            <!-- 필터 -->
            <div class="filters">
                <label for="main-category-filter">분류:</label>
                <select id="main-category-filter" class="filter-select">
                    <option value="">전체</option>
                    <option value="korean_dish">한식-요리</option>
                    <option value="korean_tang">한식-탕</option>
                    <option value="korean_jjigae">한식-찌개</option>
                    <option value="korean_guk">한식-국</option>
                    <option value="foreign">외국요리</option>
                </select>

                <button id="add-main-recipe-btn">전체 음식 DB에서 추가</button>
            </div>

            <!-- 메인요리 테이블 -->
            <table class="meal-list-table">
                <thead>
                    <tr>
                        <th>음식명</th>
                        <th>분류</th>
                        <th>조식</th>
                        <th>중식</th>
                        <th>석식</th>
                        <th>활성</th>
                        <th>메모</th>
                        <th>액션</th>
                    </tr>
                </thead>
                <tbody id="main-dish-list">
                    <!-- 메인요리 항목이 여기에 동적으로 추가됩니다 -->
                </tbody>
            </table>

            <!-- 페이지네이션 -->
            <div id="main-pagination" class="pagination">
                <!-- 페이지네이션 버튼이 여기에 동적으로 추가됩니다 -->
            </div>
        </div>

        <!-- 반찬 탭 -->
        <div id="side-dish" class="tab-content">
            <h2>반찬 관리</h2>

            <button id="add-side-recipe-btn">전체 음식 DB에서 추가</button>

            <!-- 반찬 테이블 -->
            <table class="meal-list-table">
                <thead>
                    <tr>
                        <th>음식명</th>
                        <th>분류</th>
                        <th>활성</th>
                        <th>메모</th>
                        <th>액션</th>
                    </tr>
                </thead>
                <tbody id="side-dish-list">
                    <!-- 반찬 항목이 여기에 동적으로 추가됩니다 -->
                </tbody>
            </table>

            <!-- 페이지네이션 -->
            <div id="side-pagination" class="pagination">
                <!-- 페이지네이션 버튼이 여기에 동적으로 추가됩니다 -->
            </div>
        </div>

        <!-- 야식/별식 탭 -->
        <div id="special" class="tab-content">
            <h2>야식/별식 관리</h2>

            <button id="add-special-recipe-btn">전체 음식 DB에서 추가</button>

            <!-- 야식/별식 테이블 -->
            <table class="meal-list-table">
                <thead>
                    <tr>
                        <th>음식명</th>
                        <th>분류</th>
                        <th>활성</th>
                        <th>메모</th>
                        <th>액션</th>
                    </tr>
                </thead>
                <tbody id="special-dish-list">
                    <!-- 야식/별식 항목이 여기에 동적으로 추가됩니다 -->
                </tbody>
            </table>

            <!-- 페이지네이션 -->
            <div id="special-pagination" class="pagination">
                <!-- 페이지네이션 버튼이 여기에 동적으로 추가됩니다 -->
            </div>
        </div>
    </main>

    <!-- 레시피 추가 모달 -->
    <div id="add-recipe-modal" class="modal">
        <div class="modal-content">
            <span class="close">&times;</span>
            <h2>음식 DB에서 추가</h2>

            <!-- 필터 -->
            <div class="filters">
                <label for="recipe-category-filter">분류:</label>
                <select id="recipe-category-filter" class="filter-select">
                    <option value="">전체</option>
                    <option value="main_dish">메인요리</option>
                    <option value="side_dish">반찬</option>
                    <option value="special">야식/별식</option>
                </select>

                <label for="recipe-dish-type-filter">세부 분류:</label>
                <select id="recipe-dish-type-filter" class="filter-select">
                    <option value="">전체</option>
                    <option value="korean_dish">한식-요리</option>
                    <option value="korean_tang">한식-탕</option>
                    <option value="korean_jjigae">한식-찌개</option>
                    <option value="korean_guk">한식-국</option>
                    <option value="foreign">외국요리</option>
                    <option value="side">반찬</option>
                    <option value="special">야식/별식</option>
                </select>

                <button id="search-recipes-btn">검색</button>
            </div>

            <!-- 레시피 목록 테이블 -->
            <table class="meal-list-table">
                <thead>
                    <tr>
                        <th>음식명</th>
                        <th>분류</th>
                        <th>세부 분류</th>
                        <th>액션</th>
                    </tr>
                </thead>
                <tbody id="recipe-list">
                    <!-- 레시피 항목이 여기에 동적으로 추가됩니다 -->
                </tbody>
            </table>

            <!-- 페이지네이션 -->
            <div id="recipe-pagination" class="pagination">
                <!-- 페이지네이션 버튼이 여기에 동적으로 추가됩니다 -->
            </div>
        </div>
    </div>

    <script>
        // 현재 활성화된 탭 추적
        let activeTab = 'main-dish';

        // 현재 페이지 정보 추적
        const paginationInfo = {
            'main-dish': { page: 1, totalPages: 1 },
            'side-dish': { page: 1, totalPages: 1 },
            'special': { page: 1, totalPages: 1 },
            'recipes': { page: 1, totalPages: 1 }
        };

        // 탭 전환
        document.querySelectorAll('.tab').forEach(tab => {
            tab.addEventListener('click', function() {
                // 모든 탭의 active 클래스 제거
                document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
                document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));

                // 클릭된 탭과 해당 콘텐츠에 active 클래스 추가
                this.classList.add('active');
                const tabId = this.getAttribute('data-tab');
                document.getElementById(tabId).classList.add('active');

                // 활성 탭 업데이트
                activeTab = tabId;

                // 해당 탭의 데이터 로드
                loadTabData(tabId);
            });
        });

        // 탭 데이터 로드
        async function loadTabData(tabId) {
            switch(tabId) {
                case 'main-dish':
                    await loadMainDishes();
                    break;
                case 'side-dish':
                    await loadSideDishes();
                    break;
                case 'special':
                    await loadSpecialDishes();
                    break;
            }
        }

        // 메인요리 로드
        async function loadMainDishes(page = 1) {
            try {
                const categoryFilter = document.getElementById('main-category-filter').value;
                const response = await fetch(`/api/meal-list?page=${page}&limit=10&category=main_dish${categoryFilter ? `&dish_type=${categoryFilter}` : ''}`);
                const data = await response.json();

                // 페이지네이션 정보 업데이트
                paginationInfo['main-dish'] = {
                    page: data.pagination.currentPage,
                    totalPages: data.pagination.totalPages
                };

                // 테이블 내용 업데이트
                const tbody = document.getElementById('main-dish-list');
                tbody.innerHTML = '';

                data.items.forEach(item => {
                    const row = document.createElement('tr');
                    row.innerHTML = `
                        <td>${item.name}</td>
                        <td>${item.dish_type}</td>
                        <td class="checkbox-cell"><input type="checkbox" ${item.can_breakfast ? 'checked' : ''} onchange="updateMealTime(${item.id}, 'breakfast', this.checked)"></td>
                        <td class="checkbox-cell"><input type="checkbox" ${item.can_lunch ? 'checked' : ''} onchange="updateMealTime(${item.id}, 'lunch', this.checked)"></td>
                        <td class="checkbox-cell"><input type="checkbox" ${item.can_dinner ? 'checked' : ''} onchange="updateMealTime(${item.id}, 'dinner', this.checked)"></td>
                        <td class="checkbox-cell"><input type="checkbox" ${item.is_active ? 'checked' : ''} onchange="updateActiveStatus(${item.id}, this.checked)"></td>
                        <td>${item.memo || ''}</td>
                        <td><button onclick="removeFromMealList(${item.id})">제거</button></td>
                    `;
                    tbody.appendChild(row);
                });

                // 페이지네이션 버튼 업데이트
                updatePagination('main-pagination', 'main-dish', data.pagination);
            } catch (error) {
                console.error('메인요리 로드 오류:', error);
            }
        }

        // 반찬 로드
        async function loadSideDishes(page = 1) {
            try {
                const response = await fetch(`/api/meal-list?page=${page}&limit=10&category=side_dish`);
                const data = await response.json();

                // 페이지네이션 정보 업데이트
                paginationInfo['side-dish'] = {
                    page: data.pagination.currentPage,
                    totalPages: data.pagination.totalPages
                };

                // 테이블 내용 업데이트
                const tbody = document.getElementById('side-dish-list');
                tbody.innerHTML = '';

                data.items.forEach(item => {
                    const row = document.createElement('tr');
                    row.innerHTML = `
                        <td>${item.name}</td>
                        <td>${item.dish_type}</td>
                        <td class="checkbox-cell"><input type="checkbox" ${item.is_active ? 'checked' : ''} onchange="updateActiveStatus(${item.id}, this.checked)"></td>
                        <td>${item.memo || ''}</td>
                        <td><button onclick="removeFromMealList(${item.id})">제거</button></td>
                    `;
                    tbody.appendChild(row);
                });

                // 페이지네이션 버튼 업데이트
                updatePagination('side-pagination', 'side-dish', data.pagination);
            } catch (error) {
                console.error('반찬 로드 오류:', error);
            }
        }

        // 야식/별식 로드
        async function loadSpecialDishes(page = 1) {
            try {
                const response = await fetch(`/api/meal-list?page=${page}&limit=10&category=special`);
                const data = await response.json();

                // 페이지네이션 정보 업데이트
                paginationInfo['special'] = {
                    page: data.pagination.currentPage,
                    totalPages: data.pagination.totalPages
                };

                // 테이블 내용 업데이트
                const tbody = document.getElementById('special-dish-list');
                tbody.innerHTML = '';

                data.items.forEach(item => {
                    const row = document.createElement('tr');
                    row.innerHTML = `
                        <td>${item.name}</td>
                        <td>${item.dish_type}</td>
                        <td class="checkbox-cell"><input type="checkbox" ${item.is_active ? 'checked' : ''} onchange="updateActiveStatus(${item.id}, this.checked)"></td>
                        <td>${item.memo || ''}</td>
                        <td><button onclick="removeFromMealList(${item.id})">제거</button></td>
                    `;
                    tbody.appendChild(row);
                });

                // 페이지네이션 버튼 업데이트
                updatePagination('special-pagination', 'special', data.pagination);
            } catch (error) {
                console.error('야식/별식 로드 오류:', error);
            }
        }

        // 페이지네이션 버튼 업데이트
        function updatePagination(containerId, tabId, pagination) {
            const container = document.getElementById(containerId);
            container.innerHTML = '';

            // 이전 버튼
            if (pagination.hasPrev) {
                const prevBtn = document.createElement('button');
                prevBtn.textContent = '이전';
                prevBtn.onclick = () => changePage(tabId, pagination.currentPage - 1);
                container.appendChild(prevBtn);
            }

            // 페이지 번호 버튼
            for (let i = 1; i <= pagination.totalPages; i++) {
                const pageBtn = document.createElement('button');
                pageBtn.textContent = i;
                pageBtn.onclick = () => changePage(tabId, i);
                if (i === pagination.currentPage) {
                    pageBtn.classList.add('active');
                }
                container.appendChild(pageBtn);
            }

            // 다음 버튼
            if (pagination.hasNext) {
                const nextBtn = document.createElement('button');
                nextBtn.textContent = '다음';
                nextBtn.onclick = () => changePage(tabId, pagination.currentPage + 1);
                container.appendChild(nextBtn);
            }
        }

        // 페이지 변경
        async function changePage(tabId, page) {
            switch(tabId) {
                case 'main-dish':
                    await loadMainDishes(page);
                    break;
                case 'side-dish':
                    await loadSideDishes(page);
                    break;
                case 'special':
                    await loadSpecialDishes(page);
                    break;
                case 'recipes':
                    await loadRecipes(page);
                    break;
            }
        }

        // 식사 시간 업데이트
        async function updateMealTime(itemId, mealType, isChecked) {
            try {
                // 현재 항목 정보 가져오기
                const response = await fetch(`/api/meal-list/${itemId}`);
                const item = await response.json();

                // 업데이트할 데이터 준비
                const updateData = {
                    can_breakfast: mealType === 'breakfast' ? (isChecked ? 1 : 0) : item.can_breakfast,
                    can_lunch: mealType === 'lunch' ? (isChecked ? 1 : 0) : item.can_lunch,
                    can_dinner: mealType === 'dinner' ? (isChecked ? 1 : 0) : item.can_dinner,
                    is_active: item.is_active,
                    memo: item.memo || ''
                };

                // 항목 업데이트
                await fetch(`/api/meal-list/${itemId}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(updateData)
                });

                // 성공 메시지 표시
                console.log(`${mealType} 시간 설정이 업데이트되었습니다.`);
            } catch (error) {
                console.error('식사 시간 업데이트 오류:', error);
            }
        }

        // 활성 상태 업데이트
        async function updateActiveStatus(itemId, isChecked) {
            try {
                // 현재 항목 정보 가져오기
                const response = await fetch(`/api/meal-list/${itemId}`);
                const item = await response.json();

                // 업데이트할 데이터 준비
                const updateData = {
                    can_breakfast: item.can_breakfast,
                    can_lunch: item.can_lunch,
                    can_dinner: item.can_dinner,
                    is_active: isChecked ? 1 : 0,
                    memo: item.memo || ''
                };

                // 항목 업데이트
                await fetch(`/api/meal-list/${itemId}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(updateData)
                });

                // 성공 메시지 표시
                console.log('활성 상태가 업데이트되었습니다.');
            } catch (error) {
                console.error('활성 상태 업데이트 오류:', error);
            }
        }

        // meal_list에서 제거
        async function removeFromMealList(itemId) {
            if (confirm('정말로 이 항목을 식단 구성 리스트에서 제거하시겠습니까?')) {
                try {
                    await fetch(`/api/meal-list/${itemId}`, {
                        method: 'DELETE'
                    });

                    // 현재 탭의 데이터 다시 로드
                    loadTabData(activeTab);
                } catch (error) {
                    console.error('항목 제거 오류:', error);
                }
            }
        }

        // 모달 관련 기능
        const modal = document.getElementById('add-recipe-modal');
        const closeBtn = document.querySelector('.close');

        // 모달 열기
        document.getElementById('add-main-recipe-btn').addEventListener('click', () => openModal('main_dish'));
        document.getElementById('add-side-recipe-btn').addEventListener('click', () => openModal('side_dish'));
        document.getElementById('add-special-recipe-btn').addEventListener('click', () => openModal('special'));

        function openModal(category) {
            currentCategory = category;
            modal.style.display = 'block';
            loadRecipes(1, category);
        }

        // 모달 닫기
        closeBtn.addEventListener('click', () => {
            modal.style.display = 'none';
        });

        window.addEventListener('click', (event) => {
            if (event.target == modal) {
                modal.style.display = 'none';
            }
        });

        // 현재 선택된 카테고리 추적
        let currentCategory = 'main_dish';

        // 레시피 로드
        async function loadRecipes(page = 1, category = null) {
            try {
                const categoryFilter = document.getElementById('recipe-category-filter').value;
                const dishTypeFilter = document.getElementById('recipe-dish-type-filter').value;

                let url = `/api/meal-list/not-in-list?page=${page}&limit=10`;
                if (categoryFilter) url += `&category=${categoryFilter}`;
                if (dishTypeFilter) url += `&dish_type=${dishTypeFilter}`;

                const response = await fetch(url);
                const data = await response.json();

                // 페이지네이션 정보 업데이트
                paginationInfo['recipes'] = {
                    page: data.pagination.currentPage,
                    totalPages: data.pagination.totalPages
                };

                // 테이블 내용 업데이트
                const tbody = document.getElementById('recipe-list');
                tbody.innerHTML = '';

                data.recipes.forEach(recipe => {
                    const row = document.createElement('tr');
                    row.innerHTML = `
                        <td>${recipe.name}</td>
                        <td>${recipe.food_category}</td>
                        <td>${recipe.dish_type}</td>
                        <td><button onclick="addToMealList(${recipe.id})">추가</button></td>
                    `;
                    tbody.appendChild(row);
                });

                // 페이지네이션 버튼 업데이트
                updatePagination('recipe-pagination', 'recipes', data.pagination);
            } catch (error) {
                console.error('레시피 로드 오류:', error);
            }
        }

        // meal_list에 추가
        async function addToMealList(recipeId) {
            try {
                const addData = {
                    recipe_id: recipeId,
                    can_breakfast: 0,
                    can_lunch: 1,
                    can_dinner: 1,
                    memo: ''
                };

                // 메인요리인 경우 식사 시간 설정 필요
                if (currentCategory === 'main_dish') {
                    // 기본적으로 중식과 석식만 허용 (사용자가 나중에 수정 가능)
                    addData.can_breakfast = 0;
                    addData.can_lunch = 1;
                    addData.can_dinner = 1;
                }

                const response = await fetch('/api/meal-list', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(addData)
                });

                if (response.ok) {
                    // 성공 메시지 표시
                    alert('식단 구성 리스트에 추가되었습니다.');

                    // 모달 닫기
                    document.getElementById('add-recipe-modal').style.display = 'none';

                    // 현재 탭의 데이터 다시 로드
                    loadTabData(activeTab);
                } else {
                    const errorData = await response.json();
                    alert(`추가 실패: ${errorData.error}`);
                }
            } catch (error) {
                console.error('항목 추가 오류:', error);
                alert('항목 추가 중 오류가 발생했습니다.');
            }
        }

        // 검색 버튼 이벤트
        document.getElementById('search-recipes-btn').addEventListener('click', () => loadRecipes(1));

        // 분류 필터 변경 이벤트
        document.getElementById('main-category-filter').addEventListener('change', () => loadMainDishes(1));

        // 페이지 로드 시 초기 데이터 로드
        document.addEventListener('DOMContentLoaded', () => {
            loadMainDishes();
        });
    </script>
</body>
</html>